---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/sections/Breadcrumbs.astro";
import BreadcrumbJsonLd from "@components/seo/BreadcrumbJsonLd.astro";
import Card from "@components/ui/Card.astro";
import { url } from "@lib/url";
import { getCollection } from "astro:content";
import { ArrowUpRight } from "@lucide/astro";

const all = await getCollection("blog", ({ data }) => !data.draft);
const posts = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) => d.toLocaleDateString("ru-RU", { day: "numeric", month: "long", year: "numeric" });
---

<BaseLayout title="Блог — советы по охране объектов" description="Статьи о выборе сигнализации, отличиях ЧОП и Росгвардии, настройке охраны дома и бизнеса.">
  <Breadcrumbs items={[{ name: "Блог", href: "/blog" }]} />
  <BreadcrumbJsonLd items={[{ name: "Главная", href: "/" }, { name: "Блог", href: "/blog" }]} />

  <section class="pt-8 pb-8">
    <div class="container-tight max-w-3xl">
      <span class="eyebrow">Блог</span>
      <h1 class="mt-4 font-display text-display-lg text-ink">Полезное про охрану</h1>
      <p class="mt-3 text-body-lg text-ink-muted">Как выбрать сигнализацию, чем ЧОП отличается от вневедомственной охраны, сколько стоит защитить дом — разбираемся без воды.</p>
    </div>
  </section>

  <section class="section pt-4">
    <div class="container-tight">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a href={url(`/blog/${post.id}`)} class="group">
            <Card hover padding="md" class="h-full">
              <div class="text-xs uppercase tracking-widest text-ink-subtle">
                <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
                {post.data.tags.length > 0 && <span> · {post.data.tags.slice(0, 2).join(", ")}</span>}
              </div>
              <h2 class="mt-3 font-display text-xl text-ink group-hover:text-accent transition-colors">{post.data.title}</h2>
              <p class="mt-2 text-sm text-ink-muted">{post.data.description}</p>
              <div class="mt-4 inline-flex items-center gap-1 text-sm text-accent">
                Читать
                <ArrowUpRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
              </div>
            </Card>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

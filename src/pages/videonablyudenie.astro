---
import ServiceLayout from "@layouts/ServiceLayout.astro";
import { getServiceType } from "@data/service-types";

const svc = getServiceType("videonablyudenie")!;
---

<ServiceLayout
  title={svc.metaTitle}
  description={svc.metaDescription}
  breadcrumbs={[{ name: "Услуги", href: "/pultovaya-ohrana" }, { name: "Видеонаблюдение", href: svc.url }]}
  heroKicker={svc.kicker}
  heroTitle={svc.title}
  heroSubtitle={svc.subtitle}
  heroImage={svc.image}
  priceFrom={svc.priceFrom}
  priceUnit={svc.priceUnit}
  intro={svc.intro}
  benefits={svc.benefits}
  includes={svc.includes}
  additional={svc.additional}
  process={svc.process}
  faq={svc.faq}
  serviceName={svc.title}
  serviceUrl={svc.url}
/>

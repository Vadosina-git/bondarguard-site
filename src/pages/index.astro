---
import BaseLayout from "@layouts/BaseLayout.astro";
import LocalBusinessJsonLd from "@components/seo/LocalBusinessJsonLd.astro";
import HeroSlider from "@components/sections/HeroSlider.astro";
import TrustBar from "@components/sections/TrustBar.astro";
import ServiceTiles from "@components/sections/ServiceTiles.astro";
import ServicesGrid from "@components/sections/ServicesGrid.astro";
import HowItWorks from "@components/sections/HowItWorks.astro";
import Stats from "@components/sections/Stats.astro";
import Coverage from "@components/sections/Coverage.astro";
import Gallery from "@components/sections/Gallery.astro";
import SquadStrip from "@components/sections/SquadStrip.astro";
import MobileApp from "@components/sections/MobileApp.astro";
import TeamGrid from "@components/sections/TeamGrid.astro";
import Reviews from "@components/sections/Reviews.astro";
import FAQ from "@components/sections/FAQ.astro";
import ConsultationForm from "@components/sections/ConsultationForm.astro";
import CTASection from "@components/sections/CTASection.astro";
import ParallaxBand from "@components/sections/ParallaxBand.astro";
import { site } from "@data/site";

const title = `Пультовая охрана в ${site.city} — ${site.companyName}`;
const description = `Охрана домов, квартир и бизнеса в ${site.city} с выездом ГБР за ${site.gbrTimeCity}. Пультовая охрана, сигнализация, видеонаблюдение. Звоните: ${site.phone}.`;
---

<BaseLayout title={title} description={description}>
  <LocalBusinessJsonLd />

  <HeroSlider />
  <TrustBar />

  <div class="surface-plain">
    <ServiceTiles />
  </div>

  <ParallaxBand
    image="images/hero/villa-night.jpg"
    eyebrow="Глубина защиты"
    title="Датчики видят. Операторы слышат. ГБР приезжает."
    text="Три уровня защиты работают в связке 24/7. Вы живёте — мы следим за периметром, за сигналом и за тем, чтобы экипаж уже был в пути при малейшей угрозе."
    ctaLabel="Заказать консультацию"
    ctaAction="modal-call"
  />

  <div class="surface-tinted">
    <ServicesGrid />
  </div>

  <div class="surface-plain">
    <HowItWorks />
  </div>

  <div class="surface-tinted">
    <Stats />
    <Coverage variant="country" />
  </div>

  <div class="surface-plain">
    <Gallery />
  </div>

  <div class="surface-plain">
    <SquadStrip />
  </div>

  <ParallaxBand
    image="images/hero/camo-soldier.jpg"
    eyebrow="Группа быстрого реагирования"
    title={`${site.coverage.patrolCount}+ экипажей на маршруте прямо сейчас`}
    text="Распределённая сеть ГБР по городу и области. На тревогу выезжает ближайший — не тот, у кого «свободный день»."
    height="md"
  />

  <div class="surface-tinted">
    <MobileApp />
  </div>

  <CTASection />

  <div class="surface-tinted">
    <TeamGrid />
  </div>

  <Reviews />

  <div class="surface-tinted">
    <FAQ />
  </div>

  <ConsultationForm />
</BaseLayout>

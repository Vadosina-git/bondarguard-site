---
import ServiceLayout from "@layouts/ServiceLayout.astro";
import Coverage from "@components/sections/Coverage.astro";
import { getObjectService } from "@data/services";
import { faqGeneral } from "@data/faq";

const svc = getObjectService("ohrana-kvartir")!;
---

<ServiceLayout
  title={svc.metaTitle}
  description={svc.metaDescription}
  breadcrumbs={[{ name: "Охраняем", href: "/ohrana-domov" }, { name: "Квартиры", href: svc.url }]}
  heroKicker={svc.heroKicker}
  heroTitle={svc.title}
  heroSubtitle={svc.subtitle}
  heroImage={svc.image}
  priceFrom={svc.priceFrom}
  priceUnit={svc.priceUnit}
  intro={svc.intro}
  benefits={svc.benefits}
  includes={svc.includes}
  additional={svc.additional}
  process={svc.process}
  faq={faqGeneral}
  serviceName={svc.title}
  serviceUrl={svc.url}
>
  <Coverage slot="extra" variant="city" />
</ServiceLayout>

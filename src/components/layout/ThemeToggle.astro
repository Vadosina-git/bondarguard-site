---
export interface Props { class?: string; label?: string; }
const { class: className = "", label = "Переключить тему" } = Astro.props;
---

<button
  type="button"
  class={`relative grid h-11 w-11 place-items-center rounded-btn border border-border bg-bg-elevated/60 text-ink transition-colors hover:border-accent hover:text-accent ${className}`}
  aria-label={label}
  data-theme-toggle
>
  <svg data-theme-icon="dark" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
  <svg data-theme-icon="light" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
  </svg>
</button>

<script>
  const syncIcons = () => {
    const isLight = document.documentElement.classList.contains("light");
    document.querySelectorAll<HTMLElement>('[data-theme-icon="dark"]').forEach((el) => el.classList.toggle("hidden", !isLight));
    document.querySelectorAll<HTMLElement>('[data-theme-icon="light"]').forEach((el) => el.classList.toggle("hidden", isLight));
  };

  const init = () => {
    syncIcons();
    document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((btn) => {
      if ((btn as any)._themeBound) return;
      (btn as any)._themeBound = true;
      btn.addEventListener("click", () => {
        const next = document.documentElement.classList.contains("light") ? "dark" : "light";
        document.documentElement.classList.toggle("light", next === "light");
        try { localStorage.setItem("theme", next); } catch {}
        syncIcons();
      });
    });
  };

  document.addEventListener("DOMContentLoaded", init);
</script>

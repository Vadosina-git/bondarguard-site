---
import { site } from "@data/site";
import { footerNav } from "@data/navigation";
import { url } from "@lib/url";
import { Phone, Mail, MapPin, Clock } from "@lucide/astro";

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border bg-bg-elevated/30">
  <div class="container-tight py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-[1.25fr_1fr_1fr_1fr_1fr]">
      <div>
        <a href={url()} class="inline-flex items-center gap-3 text-ink" aria-label={site.companyName}>
          <svg class="h-10 w-auto" viewBox="0 0 260 56" aria-hidden="true">
            <g transform="translate(6,6)" fill="none" stroke="#00D4AA" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 1.5 L41 6.5 V18 C41 26.8 33.5 33.4 22 36 C10.5 33.4 3 26.8 3 18 V6.5 Z"/>
              <path d="M13.2 19 L18.8 24.6 L30.6 13"/>
            </g>
            <text x="58" y="37" font-family="Onest Variable, Onest, system-ui, sans-serif" font-weight="700" font-size="20" letter-spacing="0.8" fill="currentColor">BONDAR’ GUARD</text>
          </svg>
        </a>
        <p class="mt-4 max-w-xs text-sm text-ink-muted">{site.tagline}</p>

        <ul class="mt-6 space-y-2 text-sm">
          <li class="flex items-start gap-2 text-ink-muted"><Phone class="mt-0.5 h-4 w-4 text-accent shrink-0" /><a href={`tel:${site.phoneTel}`} class="hover:text-ink">{site.phone}</a></li>
          <li class="flex items-start gap-2 text-ink-muted"><Mail class="mt-0.5 h-4 w-4 text-accent shrink-0" /><a href={`mailto:${site.email}`} class="hover:text-ink">{site.email}</a></li>
          <li class="flex items-start gap-2 text-ink-muted"><MapPin class="mt-0.5 h-4 w-4 text-accent shrink-0" />{site.address}</li>
          <li class="flex items-start gap-2 text-ink-muted"><Clock class="mt-0.5 h-4 w-4 text-accent shrink-0" />{site.workingHours}</li>
        </ul>
      </div>

      {Object.values(footerNav).map((col) => (
        <div>
          <h3 class="text-sm font-display uppercase tracking-wider text-ink">{col.title}</h3>
          <ul class="mt-4 space-y-2 text-sm">
            {col.items.map((item) => (
              <li><a href={url(item.href)} class="text-ink-muted transition-colors hover:text-accent">{item.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col justify-between gap-4 border-t border-border pt-8 text-xs text-ink-subtle md:flex-row">
      <div>© {year} {site.companyName}. Все права защищены.</div>
      <div class="flex flex-wrap items-center gap-4">
        <span>ИНН: {site.inn}</span>
        <span>ОГРН: {site.ogrn}</span>
        <a href={url("/policy")} class="hover:text-ink">Политика конфиденциальности</a>
      </div>
    </div>
  </div>
</footer>

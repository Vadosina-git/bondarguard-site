---
import { Timer, Shield, Users } from "@lucide/astro";
import { site } from "@data/site";

const items = [
  { icon: Timer, title: `ГБР ${site.gbrTimeCity}`, text: "SLA в договоре" },
  { icon: Shield, title: "Вооружённый ГБР", text: "Право задержания" },
  { icon: Users, title: "Свой пульт 24/7", text: "GSM + Ethernet" },
];
---

<section class="py-10 sm:py-14">
  <div class="container-tight">
    <div class="grid gap-6 md:grid-cols-3">
      {items.map((item) => (
        <div class="flex items-center gap-4" data-reveal>
          <span class="icon-pill"><item.icon /></span>
          <div>
            <div class="font-display text-xl text-ink">{item.title}</div>
            <p class="text-sm text-ink-muted">{item.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

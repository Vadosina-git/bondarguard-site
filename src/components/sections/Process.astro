---
export interface Step { step: string; description: string; }
export interface Props { items: Step[]; title?: string; eyebrow?: string; }
const { items, title = "Как подключаем", eyebrow = "Процесс" } = Astro.props;
---

<section class="section">
  <div class="container-tight">
    <div class="mb-10 max-w-2xl" data-reveal>
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="mt-4 font-display text-display-md text-ink">{title}</h2>
    </div>

    <ol class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {items.map((s, i) => (
        <li class="relative rounded-card border border-border bg-bg-elevated/40 p-6" data-reveal>
          <div class="font-display text-4xl text-accent/50">{String(i + 1).padStart(2, "0")}</div>
          <div class="mt-3 font-display text-lg text-ink">{s.step}</div>
          <p class="mt-2 text-sm text-ink-muted">{s.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

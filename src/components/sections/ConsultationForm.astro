---
import Input from "@components/ui/Input.astro";
import PhoneInput from "@components/ui/PhoneInput.astro";
import Button from "@components/ui/Button.astro";
import { site } from "@data/site";
import { Phone, MessageSquare, Clock } from "@lucide/astro";
---

<section class="section" id="contact">
  <div class="container-tight">
    <div class="grid items-start gap-10 rounded-block border border-border bg-bg-elevated/60 p-6 lg:grid-cols-2 lg:p-12" data-reveal>
      <div>
        <span class="eyebrow">Консультация</span>
        <h2 class="mt-4 font-display text-display-md text-ink">Рассчитать стоимость охраны</h2>
        <p class="mt-3 text-ink-muted">Оставьте контакты — инженер выедет бесплатно, посмотрит объект и предложит решение. Без «впаривания».</p>

        <ul class="mt-8 space-y-3 text-sm">
          <li class="flex items-start gap-3 text-ink-muted"><Phone class="mt-0.5 h-4 w-4 text-accent" /><a href={`tel:${site.phoneTel}`} class="hover:text-ink">{site.phone}</a></li>
          <li class="flex items-start gap-3 text-ink-muted"><Clock class="mt-0.5 h-4 w-4 text-accent" />{site.workingHours}</li>
          <li class="flex items-start gap-3 text-ink-muted"><MessageSquare class="mt-0.5 h-4 w-4 text-accent" />Отвечаем в мессенджерах в течение 15 минут</li>
        </ul>
      </div>

      <form data-lead-form data-source="home-consultation" class="space-y-4" novalidate>
        <input type="text" name="website" tabindex="-1" autocomplete="off" class="absolute -left-[9999px]" aria-hidden="true" />
        <div class="grid gap-4 sm:grid-cols-2">
          <Input name="name" label="Имя" autocomplete="name" required />
          <PhoneInput />
        </div>
        <label class="flex items-start gap-2 text-xs text-ink-muted">
          <input type="checkbox" name="consent" required class="mt-0.5 h-4 w-4 rounded border-border bg-bg text-accent" />
          <span>Согласен на обработку персональных данных и с <a href="/policy" class="underline hover:text-accent">политикой конфиденциальности</a>.</span>
        </label>
        <Button type="submit" variant="primary" size="lg" class="w-full sm:w-auto">
          <span data-btn-text>Заказать звонок</span>
        </Button>
        <p class="hidden text-sm text-success" data-form-success>Спасибо! Мы перезвоним в течение 15 минут.</p>
        <p class="hidden text-sm text-danger" data-form-error>Проверьте поля — не всё заполнено.</p>
      </form>
    </div>
  </div>
</section>

---
import Button from "@components/ui/Button.astro";
import { Phone } from "@lucide/astro";
import { site } from "@data/site";

export interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  cta?: string;
  ctaAction?: string;
  ctaHref?: string;
  compact?: boolean;
}

const { eyebrow, title, text, cta = "Заказать выезд инженера", ctaAction = "modal-call", ctaHref, compact = false } = Astro.props;
---

<section class={`${compact ? "py-10" : "section"}`} data-reveal>
  <div class="container-tight">
    <div class="gradient-border relative overflow-hidden rounded-block border border-border bg-bg-elevated px-6 py-8 md:px-12 md:py-10">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-70" style="background-image: radial-gradient(ellipse 50% 60% at 100% 0%, rgb(var(--accent) / 0.22), transparent 60%), radial-gradient(ellipse 40% 50% at 0% 100%, rgb(var(--brand) / 0.16), transparent 60%);"></div>
      <div class="relative flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
        <div class="max-w-2xl">
          {eyebrow && <span class="eyebrow">{eyebrow}</span>}
          <h3 class={`font-display text-ink ${compact ? "mt-3 text-2xl" : "mt-3 text-display-sm"}`}>{title}</h3>
          {text && <p class="mt-2 text-ink-muted">{text}</p>}
        </div>
        <div class="flex flex-col items-stretch gap-3 sm:flex-row sm:items-center md:shrink-0">
          {ctaHref ? (
            <Button href={ctaHref} variant="primary" size="lg">{cta}</Button>
          ) : (
            <Button variant="primary" size="lg">
              <span data-modal-open={ctaAction}>{cta}</span>
            </Button>
          )}
          <a href={`tel:${site.phoneTel}`} class="inline-flex items-center justify-center gap-2 rounded-btn border border-border px-4 py-3 text-sm font-semibold text-ink transition-colors hover:border-accent hover:text-accent">
            <Phone class="h-4 w-4 text-accent" />
            {site.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

---
import { url } from "@lib/url";

const tiles = [
  { src: "images/scenes/patrol.jpg", label: "Выезд ГБР", caption: "Реагирование в пределах SLA" },
  { src: "images/scenes/team-meeting.jpg", label: "Команда", caption: "Ежедневный разбор инцидентов" },
  { src: "images/scenes/camera-tech.jpg", label: "Монтаж", caption: "Подключаем камеры и панели под ключ" },
  { src: "images/scenes/cctv.jpg", label: "Видеонаблюдение", caption: "IP-камеры и видеоаналитика" },
  { src: "images/hero/operator.jpg", label: "Пульт", caption: "24/7 мониторинговый центр" },
  { src: "images/hero/guard.jpg", label: "Форма", caption: "Экипировка и средства защиты" },
];
---

<section class="section" data-reveal>
  <div class="container-tight">
    <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <span class="eyebrow">В работе</span>
        <h2 class="mt-4 font-display text-display-lg text-ink">Каждый день — защищаем объекты</h2>
        <p class="mt-3 text-ink-muted">Мониторинг, монтаж, реагирование — три направления, которые работают в связке 24/7.</p>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3 md:grid-cols-3">
      {tiles.map((t, i) => (
        <a
          href="#contact"
          class={`group relative overflow-hidden rounded-card border border-border ${i === 0 ? "md:row-span-2" : ""} ${i === 3 ? "col-span-2 md:col-span-1" : ""}`}
          style={i === 0 ? "aspect-ratio: 4/5" : "aspect-ratio: 4/3"}
        >
          <img src={url(t.src)} alt={t.label} width="800" height="600" loading="lazy" class="h-full w-full object-cover transition-transform duration-700 ease-out-quart group-hover:scale-[1.06]" />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-bg via-bg/40 to-transparent"></div>
          <div class="absolute bottom-3 left-3 right-3">
            <div class="text-[10px] uppercase tracking-widest text-accent">{t.label}</div>
            <div class="text-sm text-ink">{t.caption}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

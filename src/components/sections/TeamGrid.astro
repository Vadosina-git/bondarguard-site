---
import { team } from "@data/team";
import { url } from "@lib/url";
---

<section class="section">
  <div class="container-tight">
    <div class="mb-12 max-w-2xl" data-reveal>
      <span class="eyebrow">Команда</span>
      <h2 class="mt-4 font-display text-display-lg text-ink">Люди, которые отвечают за ваш объект</h2>
      <p class="mt-3 text-ink-muted">Мониторинговый центр, группы реагирования, инженеры. Каждый на своём месте.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
      {team.map((m) => (
        <article class="group relative overflow-hidden rounded-card border border-border bg-bg-elevated/60 transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:shadow-glow" data-reveal>
          <div class="relative aspect-[4/5] w-full overflow-hidden">
            <img
              src={url(m.photo)}
              alt={`${m.name}, ${m.role}`}
              width="480"
              height="600"
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-700 ease-out-quart group-hover:scale-[1.04]"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-bg via-bg/60 to-transparent" />
            <div class="pointer-events-none absolute inset-x-0 bottom-0 p-5">
              <div class="font-display text-xl text-ink">{m.name}</div>
              <div class="mt-0.5 text-xs text-ink-muted">{m.role}</div>
            </div>
            <div class="pointer-events-none absolute right-3 top-3 rounded-full border border-accent/30 bg-bg/50 px-2 py-0.5 text-[10px] uppercase tracking-widest text-accent backdrop-blur">
              {m.initials}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

---
import { team } from "@data/team";
import Card from "@components/ui/Card.astro";
---

<section class="section">
  <div class="container-tight">
    <div class="mb-12 max-w-2xl" data-reveal>
      <span class="eyebrow">Команда</span>
      <h2 class="mt-4 font-display text-display-lg text-ink">Люди, которые отвечают за ваш объект</h2>
      <p class="mt-3 text-ink-muted">Мониторинговый центр, группы реагирования, инженеры. Каждый на своём месте.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {team.map((m) => (
        <Card padding="sm" hover class="text-center" data-reveal>
          <div class="mx-auto grid h-24 w-24 place-items-center rounded-full border border-border bg-bg-elevated font-display text-2xl text-accent">
            {m.initials}
          </div>
          <div class="mt-4 font-display text-lg text-ink">{m.name}</div>
          <div class="text-xs text-ink-muted mt-1">{m.role}</div>
        </Card>
      ))}
    </div>
  </div>
</section>

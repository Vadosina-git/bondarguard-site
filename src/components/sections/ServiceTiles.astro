---
import Button from "@components/ui/Button.astro";
import { objectServices } from "@data/services";
import { url } from "@lib/url";
import { Home, Building2, Briefcase, TreePine, ArrowUpRight, Check } from "@lucide/astro";

const iconMap = { home: Home, apartment: Building2, business: Briefcase, dacha: TreePine };
---

<section class="section" id="services">
  <div class="container-tight">
    <div class="mb-12 max-w-2xl" data-reveal>
      <span class="eyebrow">Охраняем</span>
      <h2 class="mt-4 font-display text-display-lg text-ink">По типу объекта</h2>
      <p class="mt-3 text-ink-muted">Комплекты подобраны под сценарии использования. Смета фиксируется после бесплатного выезда инженера.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {objectServices.map((svc) => {
        const Icon = iconMap[svc.icon];
        return (
          <article class="group relative overflow-hidden rounded-card border border-border bg-bg-elevated/60 transition-all duration-300 ease-out-quart hover:-translate-y-1 hover:border-accent/40 hover:shadow-glow" data-reveal>
            <div class="relative aspect-[16/10] overflow-hidden">
              <img src={url(svc.image)} alt={svc.title} width="800" height="500" loading="lazy" class="h-full w-full object-cover transition-transform duration-700 ease-out-quart group-hover:scale-[1.05]" />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-bg-elevated via-bg-elevated/30 to-transparent"></div>
              <div class="absolute left-3 top-3">
                <div class="grid h-10 w-10 place-items-center rounded-btn bg-bg/60 text-accent backdrop-blur">
                  <Icon class="h-5 w-5" />
                </div>
              </div>
            </div>

            <div class="p-6">
              <h3 class="font-display text-2xl text-ink">{svc.shortTitle}</h3>
              <p class="mt-1 text-sm text-ink-muted">{svc.subtitle}</p>

              <div class="mt-5 rounded-btn border border-accent/30 bg-accent/10 px-4 py-3">
                <div class="text-[10px] uppercase tracking-widest text-ink-subtle">Абонентская плата</div>
                <div class="mt-0.5 font-display text-xl font-semibold text-ink">
                  от {svc.priceFrom.toLocaleString("ru-RU")} ₽<span class="text-sm font-normal text-ink-muted"> / {svc.priceUnit.replace("₽/", "").trim()}</span>
                </div>
              </div>

              <ul class="mt-5 space-y-2 text-sm">
                {svc.benefits.slice(0, 3).map((b) => (
                  <li class="flex items-start gap-2 text-ink-muted">
                    <Check class="mt-0.5 h-4 w-4 shrink-0 text-accent" />
                    <span>{b.title}</span>
                  </li>
                ))}
              </ul>

              <Button href={svc.url} variant="secondary" size="md" class="mt-6 w-full justify-between">
                Подробнее
                <ArrowUpRight class="h-4 w-4" />
              </Button>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

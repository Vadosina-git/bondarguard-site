---
import { AlertTriangle, Headset, Truck, CheckCircle2 } from "@lucide/astro";
import { url } from "@lib/url";

const steps = [
  { icon: AlertTriangle, title: "Сигнал с объекта", text: "Датчик → пульт. Основной и резервный каналы." },
  { icon: Headset, title: "Оператор на линии", text: "Звонит владельцу. Кодовое слово или выезд." },
  { icon: Truck, title: "ГБР в пути", text: "Ближайший экипаж. 5–7 мин по городу." },
  { icon: CheckCircle2, title: "Отчёт и акт", text: "Push-уведомления. Журнал событий. Документы." },
];
---

<section class="relative section overflow-hidden" id="how">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10" style="opacity: calc(var(--theme-img-opacity, 0.4) * 0.65)">
    <img src={url("images/scenes/patrol.jpg")} alt="" width="1600" height="900" loading="lazy" class="h-full w-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg/80 to-bg"></div>
  </div>
  <div class="container-tight">
    <div class="mb-12 max-w-2xl" data-reveal>
      <span class="eyebrow">Как работаем</span>
      <h2 class="mt-4 font-display text-display-lg text-ink">От сигнала до экипажа — 4 шага</h2>
    </div>

    <ol class="relative grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      <div aria-hidden="true" class="absolute left-7 top-7 h-[calc(100%-4rem)] w-px bg-gradient-to-b from-accent/40 to-transparent lg:hidden"></div>
      {steps.map((step, i) => (
        <li class="relative flex gap-4 lg:block" data-reveal>
          <span class="icon-pill"><step.icon /></span>
          <div class="lg:mt-4">
            <div class="text-xs uppercase tracking-widest text-ink-subtle">Шаг 0{i + 1}</div>
            <h3 class="mt-1 font-display text-xl text-ink">{step.title}</h3>
            <p class="mt-2 text-sm text-ink-muted">{step.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

---
import { AlertTriangle, Headset, Truck, CheckCircle2 } from "@lucide/astro";

const steps = [
  { icon: AlertTriangle, title: "Срабатывание тревоги", text: "Датчик фиксирует событие, сигнал мгновенно уходит на пульт по основному и резервному каналам." },
  { icon: Headset, title: "Обработка оператором", text: "Оператор звонит владельцу, просит кодовое слово. Если подтверждения нет — ГБР выдвигается." },
  { icon: Truck, title: "Выезд ГБР", text: "Ближайший экипаж прибывает за 5–7 минут по городу и 10–15 минут в области. Осмотр объекта, взаимодействие с МВД при необходимости." },
  { icon: CheckCircle2, title: "Отчёт и фиксация", text: "Вы получаете push-уведомления и отчёт в приложении. Акт выезда прилагается к ежемесячному документообороту." },
];
---

<section class="section bg-bg-elevated/30 border-y border-border" id="how">
  <div class="container-tight">
    <div class="mb-12 max-w-2xl" data-reveal>
      <span class="eyebrow">Как работаем</span>
      <h2 class="mt-4 font-display text-display-lg text-ink">Алгоритм обработки тревоги</h2>
      <p class="mt-3 text-ink-muted">Прозрачно и без «чёрных ящиков». Каждый шаг регламентирован и фиксируется.</p>
    </div>

    <ol class="relative grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      <div aria-hidden="true" class="absolute left-6 top-6 h-[calc(100%-3rem)] w-px bg-gradient-to-b from-accent/40 to-transparent lg:hidden" />
      {steps.map((step, i) => (
        <li class="relative flex gap-4 lg:block" data-reveal>
          <div class="relative z-10 grid h-12 w-12 shrink-0 place-items-center rounded-btn border border-accent/30 bg-bg-elevated text-accent">
            <step.icon class="h-5 w-5" />
          </div>
          <div class="lg:mt-4">
            <div class="text-xs uppercase tracking-widest text-ink-subtle">Шаг 0{i + 1}</div>
            <h3 class="mt-1 font-display text-xl text-ink">{step.title}</h3>
            <p class="mt-2 text-sm text-ink-muted">{step.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

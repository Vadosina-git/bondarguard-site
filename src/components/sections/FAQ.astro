---
import { faqGeneral } from "@data/faq";
import Accordion from "@components/ui/Accordion.astro";
import FAQJsonLd from "@components/seo/FAQJsonLd.astro";

export interface Props { items?: { question: string; answer: string }[]; title?: string; }
const { items = faqGeneral, title = "Часто задаваемые вопросы" } = Astro.props;
---

<section class="section" id="faq">
  <div class="container-tight grid gap-12 lg:grid-cols-[1fr_1.4fr]">
    <div data-reveal>
      <span class="eyebrow">FAQ</span>
      <h2 class="mt-4 font-display text-display-lg text-ink">{title}</h2>
      <p class="mt-3 text-ink-muted">Не нашли свой вопрос? <a href="#contact" class="link-underline text-accent">Задайте его напрямую</a>.</p>
    </div>

    <div data-reveal>
      <Accordion items={items} />
    </div>
  </div>
</section>

<FAQJsonLd items={items} />

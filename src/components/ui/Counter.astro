---
export interface Props {
  value: number;
  suffix?: string;
  prefix?: string;
  label: string;
  duration?: number;
  class?: string;
}

const { value, suffix = "", prefix = "", label, duration = 1800, class: className = "" } = Astro.props;
---

<div class={`flex flex-col gap-2 ${className}`}>
  <div class="font-display text-display-md text-accent" data-counter data-value={value} data-duration={duration}>
    {prefix}0{suffix}
  </div>
  <div class="text-sm uppercase tracking-wider text-ink-muted">{label}</div>
</div>

---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title: string;
  description: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description} noindex={true}>
  <section class="container-tight pt-16 pb-8">
    <h1 class="font-display text-display-md text-ink">{title}</h1>
    {lastUpdated && <p class="mt-2 text-sm text-ink-muted">Последнее обновление: {lastUpdated}</p>}
  </section>

  <section class="container-tight pb-24">
    <article class="prose-site max-w-3xl">
      <slot />
    </article>
  </section>
</BaseLayout>
